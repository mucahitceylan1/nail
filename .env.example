# --- Supabase (Dashboard: Project Settings > API) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# İkisinden biri yeterli: klasik "anon" / "public" anahtarı veya yeni "Publishable" anahtarı
VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Giriş yapan hangi e-postaların admin sayılacağı (virgülle). Ayrıca DB'de admin_users + is_admin akışı gerekir.
# VITE_ADMIN_EMAILS=admin@ornek.com

# Cloudflare Worker tabanı (sonunda / yok). İstemci `{base}/sign` ile presigned PUT alır; R2 anahtarları tarayıcıda olmaz.
# VITE_UPLOAD_SIGN_URL=https://naillabx-upload-sign.your-account.workers.dev

# R2 "Public Bucket URL" (her bucket için Cloudflare’ın verdiği https://pub-….r2.dev adresi; sonunda / yok):
# VITE_PUBLIC_MEDIA_BASE_URL_SITE_GALLERY=https://pub-xxxxx.r2.dev
# VITE_PUBLIC_MEDIA_BASE_URL_APPOINTMENT=https://pub-yyyyy.r2.dev
#
# Worker /sign 401 (invalid_token) nedeniyle yüklemeler Supabase Storage’a düşüyorsa, görseller hâlâ R2 URL’si üretmesin diye:
# VITE_SITE_GALLERY_USE_SUPABASE_PUBLIC_URL=true
# Tek CDN kökü {base}/{bucket}/{path} ile servis ediyorsa:
# VITE_PUBLIC_MEDIA_BASE_URL=https://cdn.example.com

# Opsiyonel
# VITE_SITE_URL=https://ornek.com
# VITE_GEMINI_API_KEY=
# VITE_STORE_SECRET=

# Kurulum özeti: docs/R2_ve_operasyonel_kurulum.md ve workers/README.md

# Fotoğraflar için Supabase Storage bucket adları migration ile: client-photos, appointment-media, site-gallery.
